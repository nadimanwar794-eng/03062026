rules_version = '2';

// IIC — Firestore Security Rules
// Project: project-1959318394445181665
//
// Deploy karne ke liye:
//   firebase deploy --only firestore:rules
// Ya Firebase Console → Firestore Database → Rules tab mein paste karo.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    // ── Coaching Centres ─────────────────────────────────────────────────────
    // Super Admin creates/edits centres; coaching admins read their own.
    match /coachings/{coachingId} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ── Coaching User Profiles ───────────────────────────────────────────────
    // Super admin creates profiles; coaching users read their own.
    match /coaching_users/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed();
    }

    // ── Student/User Profiles ────────────────────────────────────────────────
    // The app's custom "Account Recovery" login (Mobile/ID/Name+Class) looks
    // up a user's own document by mobile/displayId/email/name BEFORE Firebase
    // Auth has run — that query needs unauthenticated read access, or every
    // mobile/ID/email-based login silently fails with permission-denied.
    // Writes still require auth so nobody else's profile can be modified.
    match /users/{uid} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // ── All other collections ────────────────────────────────────────────────
    // Keep existing app behaviour — authenticated users can read/write.
    match /{document=**} {
      allow read, write: if isAuthed();
    }
  }
}
